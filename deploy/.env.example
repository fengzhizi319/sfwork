# ============================================================================
# sfwork 部署环境变量示例
# ============================================================================
# 用法：
#   1. 复制本文件为 deploy/.env
#   2. 填写真实值
#   3. 在 deploy/ 目录执行：docker compose up -d
#
# 说明：
#   - deploy/.env 不会被提交到 git（已在根 .gitignore 中排除）
#   - 以下仅用于本地/测试环境模板；生产环境请使用外部密钥管理
# ============================================================================

# ------------------------------------------------------------------
# 镜像版本
# ------------------------------------------------------------------
KUSCIA_IMAGE=secretflow/kuscia:latest
SECRETPAD_IMAGE=secretflow/secretpad:latest

# ------------------------------------------------------------------
# Kuscia 配置
# ------------------------------------------------------------------
KUSCIA_MASTER_NODE_ID=kuscia-master
KUSCIA_PROTOCOL=notls

# ------------------------------------------------------------------
# SecretPad 后端配置
# ------------------------------------------------------------------
KUSCIA_API_ADDRESS=kuscia-master
KUSCIA_API_PORT=8083
KUSCIA_GW_ADDRESS=kuscia-master:80
KUSCIA_PROTOCOL=notls

# SecretPad 登录账号（生产环境请修改）
SECRETPAD_USER_NAME=admin
SECRETPAD_PASSWORD=12345678

# 数据库密码（生产环境请使用强密码）
DB_PASSWORD=change-me-in-production

# JKS 密钥库密码（生产环境请使用强密码）
KEY_PASSWORD=change-me-in-production
